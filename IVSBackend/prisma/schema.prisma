// Prisma schema for Substream SDK Infrastructure

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ORGANIZATION & AUTH
// ============================================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  streams     Stream[]
  highlights  Highlight[]
  apiKeys     ApiKey[]

  @@index([slug])
}

model ApiKey {
  id          String    @id @default(uuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  hashedKey   String    @unique
  prefix      String
  scopes      String[]  @default(["streams:write", "streams:read"])
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  @@index([orgId, revokedAt])
  @@index([hashedKey])
  @@index([prefix])
}

// ============================================
// STREAMING
// ============================================

model Stream {
  id            String       @id @default(uuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  streamerId    String
  streamerName  String?
  title         String?
  status        StreamStatus @default(IDLE)

  ivsStageArn   String?
  playbackUrl   String?
  recordingUrl  String?
  thumbnailUrl  String?

  startedAt     DateTime?
  endedAt       DateTime?
  durationSecs  Int?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  highlights    Highlight[]

  @@index([orgId])
  @@index([status])
  @@index([streamerId])
  @@index([startedAt])
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
  RECORDED
}

// ============================================
// HIGHLIGHTS
// ============================================

model Highlight {
  id           String          @id @default(uuid())
  orgId        String
  org          Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  streamId     String?
  stream       Stream?         @relation(fields: [streamId], references: [id])
  title        String
  videoUrl     String?
  thumbnailUrl String?
  duration     Int?
  status       HighlightStatus @default(PENDING)
  jobId        String?         @unique
  pipelineData Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([orgId])
  @@index([streamId])
  @@index([status])
  @@index([jobId])
}

enum HighlightStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
